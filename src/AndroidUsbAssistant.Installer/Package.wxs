<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Android USB Assistant" 
           Manufacturer="AndroidUsbAssistant Team" 
           Version="1.0.0" 
           UpgradeCode="d2d3e911-3e43-4ca4-ada9-be94184cf6d4" 
           Scope="perUser">
           
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    
    <!-- Embed installation cabinet files inside MSI -->
    <MediaTemplate EmbedCab="yes" />

    <!-- Directory Structure definition -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="AndroidUsbAssistant" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Android USB Assistant" />
    </StandardDirectory>

    <!-- Component Group referencing published executable -->
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExecutable" Guid="3e439e3a-9e38-4ca4-ada9-be94184cf6d4">
        <!-- Main Exe Source -->
        <File Id="AppExe" 
              Source="$(var.AppPublishDir)\AndroidUsbAssistant.App.exe" />

        <!-- Registry key for startup auto-run -->
        <RegistryValue Root="HKCU" 
                       Key="Software\Microsoft\Windows\CurrentVersion\Run" 
                       Name="AndroidUsbAssistant" 
                       Value="&quot;[INSTALLFOLDER]AndroidUsbAssistant.App.exe&quot;" 
                       Type="string"
                       KeyPath="yes" />

        <!-- Clean up local settings folder on uninstall -->
        <RemoveFolder Id="CleanInstallFolder" Directory="INSTALLFOLDER" On="uninstall" />
      </Component>
    </ComponentGroup>

    <!-- Shortcuts Component -->
    <ComponentGroup Id="ShortcutComponents">
      <Component Id="ApplicationShortcuts" Guid="3e439e3a-9e38-4ca4-ada9-be94184cf6d5" Directory="ApplicationProgramsFolder">
        
        <!-- Start Menu Shortcut -->
        <Shortcut Id="StartMenuShortcut"
                  Name="Android USB Assistant"
                  Description="System Tray assistant for Android USB Tethering"
                  Target="[INSTALLFOLDER]AndroidUsbAssistant.App.exe"
                  WorkingDirectory="INSTALLFOLDER" />
                  
        <!-- Desktop Shortcut -->
        <Shortcut Id="DesktopShortcut"
                  Directory="DesktopFolder"
                  Name="Android USB Assistant"
                  Description="System Tray assistant for Android USB Tethering"
                  Target="[INSTALLFOLDER]AndroidUsbAssistant.App.exe"
                  WorkingDirectory="INSTALLFOLDER" />

        <!-- Start Menu folder cleanup -->
        <RemoveFolder Id="CleanShortcutFolder" Directory="ApplicationProgramsFolder" On="uninstall" />
        
        <!-- Registry entry to satisfy component keyPath requirements -->
        <RegistryValue Root="HKCU" 
                       Key="Software\AndroidUsbAssistant" 
                       Name="Installed" 
                       Value="1" 
                       Type="integer" 
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Feature Id="MainFeature" Title="Android USB Assistant Installer" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentGroupRef Id="ShortcutComponents" />
    </Feature>
  </Package>
</Wix>
